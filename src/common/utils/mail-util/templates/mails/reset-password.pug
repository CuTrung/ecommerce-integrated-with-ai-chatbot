doctype html
html
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    title Reset Password
  body(style="margin:0;padding:0;background-color:#f4f6f9;font-family:Arial,Helvetica,sans-serif;")
    table(width="100%" cellpadding="0" cellspacing="0" style="background-color:#f4f6f9;padding:40px 0;")
      tr
        td(align="center")
          table(width="600" cellpadding="0" cellspacing="0" style="background:#ffffff;border-radius:8px;padding:40px;")
            
            // Logo
            tr
              td(style="text-align:center;padding-bottom:20px;")
                img(
                  src=logoUrl
                  alt="Company Logo"
                  width="120"
                  style="display:block;margin:0 auto 20px auto;"
                )

            // Header
            tr
              td(style="text-align:center;padding-bottom:10px;")
                h2(style="margin:0;color:#333;") Reset Your Password

            // Content
            tr
              td(style="color:#555;font-size:16px;line-height:1.6;")
                p 
                  | We received a request to reset your password. 
                  | Click the button below to set a new password.
                
                p(style="margin-top:30px;text-align:center;")
                  a(
                    href=redirectTo
                    target='_blank'
                    style="display:inline-block;padding:14px 28px;background-color:#4f46e5;color:#ffffff;text-decoration:none;border-radius:6px;font-weight:bold;font-size:16px;"
                  ) Reset Password

                p(style="margin-top:30px;")
                  | If the button above doesn't work, copy and paste the following link into your browser:

                p(style="word-break:break-all;color:#4f46e5;")
                  | #{resetUrl}

                p(style="margin-top:30px;font-size:14px;color:#999;")
                  | This link will expire in 15 minutes for security reasons.
                p(style="font-size:14px;color:#999;")
                  | If you did not request a password reset, please ignore this email.

            // Footer
            tr
              td(style="padding-top:40px;text-align:center;font-size:13px;color:#aaa;")
                p(style="margin:0;") © #{new Date().getFullYear()} Your Company
                p(style="margin:5px 0 0 0;") All rights reserved.